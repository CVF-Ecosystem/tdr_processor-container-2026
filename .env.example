# .env.example
# TDR Processor - Environment Variables Configuration
# 
# This file shows all available environment variables for TDR Processor.
# Copy this to .env and set your actual values.
# IMPORTANT: Never commit .env with real credentials to version control!

# ============================================================================
# SMTP/EMAIL CONFIGURATION (REQUIRED FOR EMAIL NOTIFICATIONS)
# ============================================================================
# Email credentials should be loaded from environment variables, NOT stored in 
# configuration files. This is the most secure approach for credential handling.

# SMTP Server Username (typically your email address)
# Example: user@gmail.com
TDR_SMTP_USER=your-email@gmail.com

# SMTP Server Password or App-Specific Password
# For Gmail: Use an "App Password" from https://myaccount.google.com/apppasswords
# For Office 365: Use your application password
# Never use your actual email password!
TDR_SMTP_PASS=your-app-specific-password

# ============================================================================
# OPTIONAL SMTP CONFIGURATION
# ============================================================================
# These can be configured in the application UI as well

# SMTP Server Hostname (default: smtp.gmail.com)
# Examples: 
#   - Gmail: smtp.gmail.com
#   - Office 365: smtp.office365.com
#   - Custom server: mail.yourcompany.com
# TDR_SMTP_SERVER=smtp.gmail.com

# SMTP Server Port (default: 587 for STARTTLS)
# Valid values: 25 (SMTP), 587 (STARTTLS), 465 (SMTPS)
# TDR_SMTP_PORT=587

# ============================================================================
# RECIPIENT EMAIL CONFIGURATION (OPTIONAL)
# ============================================================================
# Can also be configured in the application UI

# Recipient email address for scheduled reports
# TDR_RECIPIENT_EMAIL=recipient@example.com

# ============================================================================
# APPLICATION CONFIGURATION (OPTIONAL)
# ============================================================================

# Application log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: DEBUG
# TDR_LOG_LEVEL=DEBUG

# Output directory for processed reports
# Default: ./outputs
# TDR_OUTPUT_DIR=./outputs

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 
# 1. CREDENTIAL HANDLING:
#    - Store credentials in environment variables, NEVER in code or config files
#    - Use strong, unique passwords or app-specific passwords
#    - Rotate credentials regularly
#
# 2. FILE PERMISSIONS:
#    - Keep .env file with restricted permissions (chmod 600 on Linux/Mac)
#    - Never share .env file or commit it to version control
#    - Add .env to .gitignore
#
# 3. GMAIL SETUP:
#    - Enable 2-factor authentication on your Google account
#    - Create an App Password: https://myaccount.google.com/apppasswords
#    - Use the 16-character app password in TDR_SMTP_PASS
#
# 4. OFFICE 365 SETUP:
#    - SMTP Server: smtp.office365.com
#    - Port: 587 (STARTTLS)
#    - Username: your-email@yourcompany.com
#    - Password: Your office password or app-specific password
#
# 5. VALIDATION:
#    - All email addresses are validated for format and injection attacks
#    - File paths are validated to prevent directory traversal attacks
#    - SMTP parameters are validated before connection attempts
#
# ============================================================================
# DEVELOPMENT VS PRODUCTION
# ============================================================================
#
# Development (.env file):
#   - Use test email accounts
#   - Use verbose logging (DEBUG)
#   - Can be more permissive for testing
#
# Production (system environment):
#   - Use application-specific credentials
#   - Use INFO or WARNING logging
#   - Strict security configuration
#   - Credentials set via system environment, not files
#
# ============================================================================
# TESTING
# ============================================================================
# 
# To test SMTP configuration:
# 1. Set the environment variables above
# 2. Run the application and use "Test Email" button in Settings
# 3. Check logs for validation errors
#
# To test without SMTP:
# 1. Leave TDR_SMTP_USER and TDR_SMTP_PASS unset
# 2. Email notifications will be skipped (logged as skipped, not error)
#
# ============================================================================
